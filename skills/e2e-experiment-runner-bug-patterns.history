    """Configuration for a tier including all sub-tests."""
    tier_id: TierID
    subtests: list[SubTestConfig]
    system_prompt_mode: str = "default"
    custom_system_prompt: str | None = None
    prompt_content: str | None = None  # NEW: from config/tiers/*.md
